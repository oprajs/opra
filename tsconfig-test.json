{
  "extends": "./tsconfig-base.json",
  "include": [
    "./packages/*/test/**/*.*",
    "./packages/*/src/**/*.*",
    "./examples/**/*.*"
  ],
  "compilerOptions": {
    "types": [
      "node",
      "mocha"
    ],
    "sourceMap": true,
    "paths": {
      "@opra/*": [
        "./packages/*/src/index.js"
      ],
      "example-customer-mongo/models": [
        "./examples/_lib/customer-mongo/src/models/index.js"
      ]
    }
  }
}
