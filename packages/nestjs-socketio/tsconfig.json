{
  "extends": "../../tsconfig-base.json",
  "include": ["src"],
  "exclude": ["build"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./build",
    "paths": {
      "@opra/common": ["../common/src/index.js"],
      "@opra/core": ["../core/src/index.js"],
      "@opra/socketio": ["../socketio/src/index.js"],
      "@opra/nestjs": ["../nestjs/src/index.js"]
    }
  },
  "references": [
    { "path": "../common" },
    { "path": "../core" },
    { "path": "../socketio" },
    { "path": "../nestjs" }
  ]
}

